volumes:

  catkin_workspace:

  shared_data:

  uav_custom_files:

  bag_files:

  logs:

services:

  # will copy session-specific data shared between containers from the shared_data container to a shared volume
  copy_catkin_workspace:
    image: uvdar_workspace:1.0.1
    volumes:
      - catkin_workspace:/tmp/docker/catkin_workspace_1:consistent
    tty: true
    command: sh -c "rm -rvf /tmp/docker/catkin_workspace_1/*; mkdir -pv /tmp/docker/catkin_workspace_1; cp -rv /etc/docker/catkin_workspace_1/* /tmp/docker/catkin_workspace_1/"

  copy_shared_data:
    image: shared_data:worlds
    volumes:
      - shared_data:/tmp/docker/shared_data:consistent
    tty: true
    command: sh -c "rm -rvf /tmp/docker/shared_data/*; mkdir -pv /tmp/docker/shared_data; cp -rv /etc/docker/shared_data/* /tmp/docker/shared_data/"

  # will copy uav-specific configs, launch files and other files from the uav-specific docker image to a shared volume
  copy_uav_custom_files:
    # image: fly4future/uav_custom_files
    image: uav_custom_files:uvdar
    volumes:
      - uav_custom_files:/tmp/docker/uav_custom_files:consistent
    tty: true
    command: sh -c "rm -rvf /tmp/docker/uav_custom_files/*; mkdir -pv /tmp/docker/uav_custom_files; cp -rv /etc/docker/uav_custom_files/${UAV_TYPE}/${UAV_ID}/* /tmp/docker/uav_custom_files/"

  # starts roscore
  # this is the first container in the ROS pipeline
  roscore:
    image: ctumrs/mrs_uav_system:${MRS_UAV_SYSTEM_VERSION}
    network_mode: host
    depends_on:
      - copy_shared_data
      - copy_uav_custom_files
    env_file:
      - ./stack.env
    tty: true
    command: roscore

  # after roscore is started
  # -> set a parameter that tells the system that simulation time is NOT used
  # this container then stops
  rostime:
    image: ctumrs/mrs_uav_system:${MRS_UAV_SYSTEM_VERSION}
    network_mode: host
    depends_on:
      - roscore
    env_file:
      - ./stack.env
    tty: true
    command: bash -c "waitForRos && rosparam set use_sim_time false"

  # starts the HW API for connecting the MRS UAV System to PX4
  hw_api:
    image: ctumrs/mrs_uav_system:${MRS_UAV_SYSTEM_VERSION}
    depends_on:
      - rostime
    network_mode: host
    volumes:
      - shared_data:/etc/docker/shared_data:consistent
      - /dev/:/dev/
    privileged: true
    env_file:
      - ./stack.env
    tty: true
    command: bash -c "waitForTime && roslaunch mrs_uav_px4_api api.launch"

  # starts the MRS UAV System's core
  uav_core:
    image: ctumrs/mrs_uav_system:${MRS_UAV_SYSTEM_VERSION}
    depends_on:
      - rostime
    network_mode: host
    volumes:
      - shared_data:/etc/docker/shared_data:consistent
    env_file:
      - ./stack.env
    tty: true
    command: bash -c "waitForHw && roslaunch mrs_uav_core core.launch platform_config:=`rospack find mrs_robofly_core`/config/platform_config.yaml custom_config:=/etc/docker/shared_data/custom_config.yaml world_config:=/etc/docker/shared_data/world_local.yaml network_config:=/etc/docker/shared_data/network_config.yaml"
  # starts the UVDAR
  uvdar_package:
    image: ctumrs/mrs_uav_system:${MRS_UAV_SYSTEM_VERSION}
    network_mode: host
    depends_on:
      - copy_catkin_workspace
      - copy_uav_custom_files
    volumes:
      - catkin_workspace:/etc/docker/catkin_workspace_1:consistent
      - uav_custom_files:/etc/docker/uav_custom_files:consistent
      - /dev/:/dev/
      - /sys/class/leds/uvled/:/sys/class/leds/uvled/
      - /run/udev:/run/udev:ro
#      - /home/uav/custom/:/etc/docker/custom/
#      - /home/uav/coredumps/:/etc/docker/coredumps/
    env_file:
      - ./stack.env
    environment:
      - LIBGL_ALWAYS_SOFTWARE=1
    tty: true
    privileged: true
    command: bash -c "waitForRos && source /etc/docker/catkin_workspace_1/devel/setup.bash && source /etc/docker/uav_custom_files/uvdar/set_ids.sh && roslaunch uvdar_core rw_one_sided_rpicam.launch calibrations_folder:=/etc/docker/uav_custom_files/"
  # starts the Reflection Node
  reflection_package:
    image: timlakemann/mrs_system_custom_python_pkg:0.0
    network_mode: host
    depends_on:
      - copy_catkin_workspace
      - copy_uav_custom_files
    volumes:
      - catkin_workspace:/etc/docker/catkin_workspace_1:consistent
      - uav_custom_files:/etc/docker/uav_custom_files:consistent
      - /dev/:/dev/
    env_file:
      - ./stack.env
    tty: true
    privileged: true
    command: bash -c "waitForRos && source /etc/docker/catkin_workspace_1/devel/setup.bash && roslaunch reflection_node reflection.launch calib_file:=/etc/docker/uav_custom_files/camera_calibrations/calib_results_rp_uv_front.txt"
#  camera_flip:
#    image: timlakemann/mrs_system_custom_python_pkg:0.0
#    network_mode: host
#    depends_on:
#      - copy_catkin_workspace
#      - copy_uav_custom_files
#    volumes:
#      - catkin_workspace:/etc/docker/catkin_workspace_1:consistent
#      - uav_custom_files:/etc/docker/uav_custom_files:consistent
#      - /dev/:/dev/
#    env_file:
#      - ./stack.env
#    tty: true
#    privileged: true
#    command: bash -c "waitForRos && source /etc/docker/catkin_workspace_1/devel/setup.bash && rosrun reflection_node image_flip_node.py _input_topic:=/uav61/uvdar_camera/front/image_raw _output_topic:=/uav61/uvdar_camera/front/image_raw"
  garmin_lidar:
    image: ctumrs/mrs_uav_system:${MRS_UAV_SYSTEM_VERSION}
    network_mode: host
    depends_on:
      - copy_catkin_workspace
      - copy_uav_custom_files
    volumes:
      - catkin_workspace:/etc/docker/catkin_workspace_1:consistent
      - uav_custom_files:/etc/docker/uav_custom_files:consistent
    devices:
      - /dev/i2c-1:/dev/i2c-1
    env_file:
      - ./stack.env
    tty: true
    command: bash -c "waitForRos && source /etc/docker/catkin_workspace_1/devel/setup.bash; roslaunch garmin_lidar garmin_lidar.launch"
  uwb_package:
    image: ctumrs/mrs_uav_system:${MRS_UAV_SYSTEM_VERSION}
    network_mode: host
    depends_on:
      - copy_catkin_workspace
      - copy_uav_custom_files
    volumes:
      - catkin_workspace:/etc/docker/catkin_workspace_1:consistent
      - uav_custom_files:/etc/docker/uav_custom_files:consistent
      - /dev/:/dev/
      - /sys/:/sys/
      - /run/udev:/run/udev
    env_file:
      - ./stack.env
    tty: true
    privileged: true
    command: bash -c "waitForRos && source /etc/docker/catkin_workspace_1/devel/setup.bash && roslaunch uvdar_ros_driver uvdar.launch serial_number:=205F33504E31"
  # starts the node that handles automatic initialization of the system and takeoff
  automatic_start:
    image: ctumrs/mrs_uav_system:${MRS_UAV_SYSTEM_VERSION}
    depends_on:
      - rostime
    network_mode: host
    volumes:
      - shared_data:/etc/docker/shared_data:consistent
    env_file:
      - ./stack.env
    tty: true
    command: bash -c "waitForHw && roslaunch mrs_uav_autostart automatic_start.launch custom_config:=/etc/docker/shared_data/automatic_start.yaml"

  # starts `rosbag record`
#  rosbag:
#    image: ctumrs/mrs_uav_system:${MRS_UAV_SYSTEM_VERSION}
#    depends_on:
#      - rostime
#    network_mode: host
#    volumes:
#      - bag_files:/etc/docker/bag_files:consistent
#      - shared_data:/etc/docker/shared_data:consistent
#    env_file:
#      - ./stack.env
#    tty: true
#    command: bash -c "waitForTime && /etc/docker/shared_data/record.sh"
  rosbag:
    image: ctumrs/mrs_uav_system:${MRS_UAV_SYSTEM_VERSION}
    depends_on:
      - rostime
    network_mode: host
    volumes:
      - /home/mrs/bags:/etc/docker/bag_files:consistent
      - shared_data:/etc/docker/shared_data:consistent
    env_file:
      - ./stack.env
    tty: true
    stop_grace_period: 10s
    command: bash -c "waitForTime && /etc/docker/shared_data/record.sh"

  rosbridge:
    image: ctumrs/mrs_uav_system:${MRS_UAV_SYSTEM_VERSION}
    network_mode: host
    env_file:
      - ./stack.env
    tty: true
    command: bash -c "waitForRos && roslaunch rosbridge_server rosbridge_websocket.launch"

  dogtail:
    image: klaxalk/dogtail:latest
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - logs:/etc/logs:consistent

  # this container can be used to access a terminal with ROS inside the compose session
  terminal:
    image: ctumrs/mrs_uav_system:${MRS_UAV_SYSTEM_VERSION}
    network_mode: host
    depends_on:
      - rostime
    env_file:
      - ./stack.env
    entrypoint: ["/bin/bash", "-c"]
    volumes:
      - bag_files:/etc/docker/bag_files:consistent
      - shared_data:/etc/docker/shared_data:consistent
      - uav_custom_files:/etc/docker/uav_custom_files:consistent
      - /dev/:/dev/
    command:
      - bash --rcfile /opt/ros/noetic/setup.bash
    privileged: true
    stdin_open: true
    tty: true
